# Generated audio artifacts (regenerate via make_synthetic_mix.py / run_demo.py)
output/*.wav
output/*.json
synth_mix.wav
reference_master.wav
*.wav.bak

# Keep the output directory tracked even though its generated contents are ignored
!output/.gitkeep
