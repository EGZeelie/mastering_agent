# Copy this file to .env (which is gitignored) and fill in your key to
# enable the real Gemini-orchestrated decision engine. Without this, the
# agent transparently falls back to the deterministic rule-based engine --
# nothing breaks, you just don't get LLM-driven reasoning.
#
#   cp .env.example .env
#   # edit .env with your real key
#   set -a && source .env && set +a   # load into your shell
#   python run_demo.py

GEMINI_API_KEY=your_gemini_api_key_here
# Alternatively, google-genai also recognizes GOOGLE_API_KEY:
# GOOGLE_API_KEY=your_google_api_key_here
